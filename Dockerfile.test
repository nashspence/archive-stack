FROM python:3.11.15-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app:/app/src

RUN apt-get update \
    && apt-get install -y --no-install-recommends xorriso \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-test.txt ./
RUN pip install --no-cache-dir --require-hashes -r requirements-test.txt

COPY pyproject.toml README.md ./
RUN mkdir -p src/arc_api src/arc_cli src/arc_core src/arc_disc \
    && touch \
        src/arc_api/__init__.py \
        src/arc_cli/__init__.py \
        src/arc_core/__init__.py \
        src/arc_disc/__init__.py \
    && pip install --no-cache-dir -e .[db]

COPY src ./src
COPY contracts ./contracts
COPY tests ./tests

ENTRYPOINT ["python", "-m", "pytest"]
CMD ["-q"]

FROM python:3.11.15-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app:/app/src

ARG WEED_VERSION=4.21
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl xorriso \
    && curl -fsSL \
       "https://github.com/seaweedfs/seaweedfs/releases/download/${WEED_VERSION}/linux_amd64_full.tar.gz" \
       | tar -xz -C /usr/local/bin weed \
    && chmod +x /usr/local/bin/weed \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-test.txt ./
RUN pip install --no-cache-dir --require-hashes -r requirements-test.txt

COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir -e .[db]

COPY . .

ENTRYPOINT ["python", "-m", "pytest"]
CMD ["-q"]
